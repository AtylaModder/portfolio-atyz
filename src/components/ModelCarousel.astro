---
import { modelCategories } from '../data/site';
---

<section id="models" class="models-section section-anchor">
  <!-- Atmospheric background -->
  <div class="models-section__bg" aria-hidden="true">
    <div class="models-section__orb models-section__orb--1"></div>
    <div class="models-section__orb models-section__orb--2"></div>
    <div class="models-section__shape models-section__shape--diamond"></div>
    <div class="models-section__shape models-section__shape--ring"></div>
  </div>

  <div class="container-shell">
    <div class="models-section__header reveal-up">
      <div>
        <span class="section-eyebrow">Modelos</span>
        <h2 class="section-title">Modelos</h2>
        <p class="section-subtitle">Uma amostra dos modelos e trabalhos criados para diversos projetos.</p>
      </div>
      <div class="models-section__filters">
        {modelCategories.map((cat, i) => (
          <button class:list={['model-filter', i === 0 && 'active']} data-category={cat.toLowerCase()}>
            {cat}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Full-bleed carousel (outside container for edge-to-edge) -->
  <div class="models-carousel-wrap" id="models-wrap">
    <div class="models-track" id="models-track"></div>
  </div>
</section>

<!-- Lightboxes — outside section to avoid stacking context isolation -->

<!-- Lightbox — Image -->
<div class="model-lightbox" id="model-lightbox" aria-hidden="true">
  <div class="model-lightbox__backdrop"></div>
  <div class="model-lightbox__body">
    <button class="model-lightbox__close" id="lb-close" aria-label="Fechar"></button>
    <img class="model-lightbox__image" id="lb-img" alt="" />
    <p class="model-lightbox__title" id="lb-title"></p>
    <p class="model-lightbox__badge" id="lb-badge"></p>
  </div>
</div>

<!-- Lightbox — 3D Viewer -->
<div class="model-lightbox model-lightbox--3d" id="model-lightbox-3d" aria-hidden="true">
  <div class="model-lightbox__backdrop"></div>
  <div class="model-lightbox-3d__body">
    <button class="model-lightbox__close" id="lb3d-close" aria-label="Fechar"></button>
    <button class="model-lightbox-3d__debug-toggle" id="lb3d-debug-toggle" type="button" aria-controls="lb3d-debug" aria-expanded="true">
      Camera
    </button>
    <div class="model-lightbox-3d__viewer-controls">
      <button class="model-lightbox-3d__lighting-toggle" id="lb3d-lighting-toggle" type="button" aria-pressed="true">
        <span class="model-lightbox-3d__lighting-label">Luz premium</span>
        <span class="model-lightbox-3d__lighting-value" id="lb3d-lighting-value">Ligada</span>
      </button>
      <p class="model-lightbox-3d__lighting-note" id="lb3d-lighting-note">AO, bloom e luz dinâmica</p>
    </div>
    <aside class="model-lightbox-3d__debug" id="lb3d-debug" data-open="true" data-lenis-prevent>
      <div class="model-lightbox-3d__debug-header">
        <div>
          <p class="model-lightbox-3d__debug-title">Camera debug</p>
          <p class="model-lightbox-3d__debug-subtitle">Valores ao vivo para colar em models</p>
        </div>
        <span class="model-lightbox-3d__debug-status" id="lb3d-debug-status">Ao vivo</span>
      </div>

      <div class="model-lightbox-3d__debug-grid">
        <div><span>Modo</span><strong id="lb3d-debug-mode">-</strong></div>
        <div><span>Ângulo</span><strong id="lb3d-debug-angle">-</strong></div>
        <div><span>Height</span><strong id="lb3d-debug-height">-</strong></div>
        <div><span>Zoom</span><strong id="lb3d-debug-zoom">-</strong></div>
        <div><span>Camera zoom</span><strong id="lb3d-debug-camera-zoom">-</strong></div>
        <div><span>Distância</span><strong id="lb3d-debug-distance">-</strong></div>
        <div><span>Pos X</span><strong id="lb3d-debug-pos-x">-</strong></div>
        <div><span>Pos Y</span><strong id="lb3d-debug-pos-y">-</strong></div>
        <div><span>Pos Z</span><strong id="lb3d-debug-pos-z">-</strong></div>
        <div><span>Target X</span><strong id="lb3d-debug-target-x">-</strong></div>
        <div><span>Target Y</span><strong id="lb3d-debug-target-y">-</strong></div>
        <div><span>Target Z</span><strong id="lb3d-debug-target-z">-</strong></div>
      </div>

      <div class="model-lightbox-3d__debug-actions">
        <button class="model-lightbox-3d__debug-btn" id="lb3d-copy-compact" type="button">Copiar base</button>
        <button class="model-lightbox-3d__debug-btn" id="lb3d-copy-exact" type="button">Copiar exata</button>
      </div>

      <p class="model-lightbox-3d__debug-label">Config base</p>
      <pre class="model-lightbox-3d__debug-code" id="lb3d-debug-compact">camera: {}</pre>

      <p class="model-lightbox-3d__debug-label">Config exata</p>
      <pre class="model-lightbox-3d__debug-code" id="lb3d-debug-exact">camera: {}</pre>
    </aside>
    <canvas class="model-lightbox-3d__canvas" id="lb3d-canvas"></canvas>
    <div class="model-lightbox-3d__info">
      <p class="model-lightbox-3d__title" id="lb3d-title"></p>
      <p class="model-lightbox-3d__hint">Arraste para girar · Botão direito para mover · Scroll para zoom</p>
    </div>
  </div>
</div>

<script>
  import { models } from '../data/site';

  type ViewerCameraConfig = {
    angle: number;
    height: number;
    zoom: number;
    lookX: number;
    lookY: number;
    lookZ?: number;
    ortho: boolean;
    positionX?: number;
    positionY?: number;
    positionZ?: number;
    targetX?: number;
    targetY?: number;
    targetZ?: number;
  };

  type ViewerRenderConfig = {
    emissive?: boolean;
    emissiveIntensity?: number;
    heightMap?: boolean | string;
    heightMapStrength?: number;
    oneSided?: boolean;
  };

  type ViewerLightingMode = 'enhanced' | 'basic';

  type ViewerCameraDebugInfo = {
    mode: 'orthographic' | 'perspective';
    angle: number;
    height: number;
    zoom: number;
    cameraZoom: number;
    distance: number;
    position: { x: number; y: number; z: number };
    target: { x: number; y: number; z: number };
    compactConfig: ViewerCameraConfig;
    exactConfig: ViewerCameraConfig;
  };

  type ModelViewerHandle = {
    dispose: () => void;
    resize: () => void;
    getCameraDebugInfo: () => ViewerCameraDebugInfo;
    setLightingMode: (mode: ViewerLightingMode) => void;
    getLightingMode: () => ViewerLightingMode;
  };

  /* ── DOM refs ──────────────────────────────────── */
  const wrap   = document.getElementById('models-wrap')!;
  const track  = document.getElementById('models-track')!;
  const lb     = document.getElementById('model-lightbox')!;
  const lbImg  = document.getElementById('lb-img') as HTMLImageElement;
  const lbTitle = document.getElementById('lb-title')!;
  const lbBadge = document.getElementById('lb-badge')!;

  // 3D lightbox
  const lb3d      = document.getElementById('model-lightbox-3d')!;
  const lb3dCanvas = document.getElementById('lb3d-canvas') as HTMLCanvasElement;
  const lb3dTitle  = document.getElementById('lb3d-title')!;
  const lb3dDebug = document.getElementById('lb3d-debug') as HTMLElement;
  const lb3dDebugToggle = document.getElementById('lb3d-debug-toggle') as HTMLButtonElement;
  const lb3dLightingToggle = document.getElementById('lb3d-lighting-toggle') as HTMLButtonElement;
  const lb3dLightingValue = document.getElementById('lb3d-lighting-value') as HTMLElement;
  const lb3dLightingNote = document.getElementById('lb3d-lighting-note') as HTMLElement;
  const lb3dDebugStatus = document.getElementById('lb3d-debug-status') as HTMLElement;
  const lb3dDebugCompact = document.getElementById('lb3d-debug-compact') as HTMLElement;
  const lb3dDebugExact = document.getElementById('lb3d-debug-exact') as HTMLElement;
  const lb3dCopyCompact = document.getElementById('lb3d-copy-compact') as HTMLButtonElement;
  const lb3dCopyExact = document.getElementById('lb3d-copy-exact') as HTMLButtonElement;
  const debugFields = {
    mode: document.getElementById('lb3d-debug-mode') as HTMLElement,
    angle: document.getElementById('lb3d-debug-angle') as HTMLElement,
    height: document.getElementById('lb3d-debug-height') as HTMLElement,
    zoom: document.getElementById('lb3d-debug-zoom') as HTMLElement,
    cameraZoom: document.getElementById('lb3d-debug-camera-zoom') as HTMLElement,
    distance: document.getElementById('lb3d-debug-distance') as HTMLElement,
    posX: document.getElementById('lb3d-debug-pos-x') as HTMLElement,
    posY: document.getElementById('lb3d-debug-pos-y') as HTMLElement,
    posZ: document.getElementById('lb3d-debug-pos-z') as HTMLElement,
    targetX: document.getElementById('lb3d-debug-target-x') as HTMLElement,
    targetY: document.getElementById('lb3d-debug-target-y') as HTMLElement,
    targetZ: document.getElementById('lb3d-debug-target-z') as HTMLElement,
  };

  /* ── State ─────────────────────────────────────── */
  let pos = 0;
  let setW = 0;
  let speed = 0.45;
  let isVisible = false;
  let isHover = false;
  let isDrag = false;
  let isPaused = false;
  let dragStartX = 0;
  let dragOrigin = 0;
  let velocity = 0;
  let lastPtrX = 0;
  let clickOk = true;
  let resumeTimer = 0;
  let activeFilter = 'all';
  let filteredCount = 0;
  let activeViewer: ModelViewerHandle | null = null;
  let ticker = 0;
  let ticking = false;
  let debugTicker = 0;
  let lastCameraDebugInfo: ViewerCameraDebugInfo | null = null;
  let modelViewerModulePromise: Promise<typeof import('../lib/bedrock-renderer')> | null = null;
  const lightingStorageKey = 'atyz-model-viewer-lighting-mode';
  let activeLightingMode: ViewerLightingMode = getStoredLightingMode();

  const defaultDebugOpen = () => window.innerWidth >= 1024;

  function getStoredLightingMode(): ViewerLightingMode {
    try {
      const stored = window.localStorage.getItem(lightingStorageKey);
      if (stored === 'enhanced' || stored === 'basic') {
        return stored;
      }
    } catch {
      // Ignore storage failures and fall back to perf heuristics.
    }

    const perfTier = (window as any).__perfTier;
    return perfTier?.isLowEnd || perfTier?.isMobile ? 'basic' : 'enhanced';
  }

  function persistLightingMode(mode: ViewerLightingMode) {
    activeLightingMode = mode;
    try {
      window.localStorage.setItem(lightingStorageKey, mode);
    } catch {
      // Ignore storage failures so the viewer still works.
    }
  }

  function updateLightingToggle(mode: ViewerLightingMode) {
    activeLightingMode = mode;
    const perfTier = (window as any).__perfTier;
    const isEnhanced = mode === 'enhanced';
    lb3dLightingToggle.setAttribute('aria-pressed', String(isEnhanced));
    lb3dLightingValue.textContent = isEnhanced ? 'Ligada' : 'Leve';
    lb3dLightingNote.textContent = isEnhanced
      ? 'AO, bloom e luz dinâmica'
      : perfTier?.isLowEnd || perfTier?.isMobile
        ? 'Modo leve para aliviar o aparelho'
        : 'Sem pós, com render mais leve';
  }

  function setLightingToggleDisabled(isDisabled: boolean) {
    lb3dLightingToggle.disabled = isDisabled;
    lb3dLightingToggle.dataset.loading = isDisabled ? 'true' : 'false';
  }

  function setDebugPanelOpen(isOpen: boolean) {
    lb3dDebug.dataset.open = isOpen ? 'true' : 'false';
    lb3dDebugToggle.setAttribute('aria-expanded', String(isOpen));
    lb3dDebugToggle.textContent = isOpen ? 'Ocultar camera' : 'Mostrar camera';
  }

  function formatValue(value: number, decimals = 3) {
    return Number.isFinite(value) ? value.toFixed(decimals) : '-';
  }

  function formatCameraConfig(config: ViewerCameraConfig, exact = false) {
    const lines = [
      'camera: {',
      `  angle: ${formatValue(config.angle, 1)},`,
      `  height: ${formatValue(config.height, 1)},`,
      `  zoom: ${formatValue(config.zoom)},`,
      `  lookX: ${formatValue(config.lookX)},`,
      `  lookY: ${formatValue(config.lookY)},`,
    ];

    if (config.lookZ !== undefined || exact) {
      lines.push(`  lookZ: ${formatValue(config.lookZ ?? 0)},`);
    }

    if (exact) {
      lines.push(`  positionX: ${formatValue(config.positionX ?? 0)},`);
      lines.push(`  positionY: ${formatValue(config.positionY ?? 0)},`);
      lines.push(`  positionZ: ${formatValue(config.positionZ ?? 0)},`);
      lines.push(`  targetX: ${formatValue(config.targetX ?? 0)},`);
      lines.push(`  targetY: ${formatValue(config.targetY ?? 0)},`);
      lines.push(`  targetZ: ${formatValue(config.targetZ ?? 0)},`);
    }

    lines.push(`  ortho: ${config.ortho},`);
    lines.push('},');

    return lines.join('\n');
  }

  function parseCameraConfig(camRaw: string): ViewerCameraConfig | undefined {
    if (!camRaw) return undefined;

    try {
      return JSON.parse(decodeURIComponent(camRaw));
    } catch {
      const parts = camRaw.split(',').map(Number);
      if (parts.length < 6) return undefined;
      const [a, h, z, lx, ly, o] = parts;
      return { angle: a, height: h, zoom: z, lookX: lx, lookY: ly, ortho: !!o };
    }
  }

  function parseRenderConfig(renderRaw: string): ViewerRenderConfig | undefined {
    if (!renderRaw) return undefined;

    try {
      return JSON.parse(decodeURIComponent(renderRaw));
    } catch {
      return undefined;
    }
  }

  function renderCameraDebug() {
    if (!activeViewer) return;

    const info = activeViewer.getCameraDebugInfo();
    lastCameraDebugInfo = info;

    debugFields.mode.textContent = info.mode === 'orthographic' ? 'Ortho' : 'Persp';
    debugFields.angle.textContent = formatValue(info.angle, 1);
    debugFields.height.textContent = formatValue(info.height, 1);
    debugFields.zoom.textContent = formatValue(info.zoom);
    debugFields.cameraZoom.textContent = formatValue(info.cameraZoom);
    debugFields.distance.textContent = formatValue(info.distance);
    debugFields.posX.textContent = formatValue(info.position.x);
    debugFields.posY.textContent = formatValue(info.position.y);
    debugFields.posZ.textContent = formatValue(info.position.z);
    debugFields.targetX.textContent = formatValue(info.target.x);
    debugFields.targetY.textContent = formatValue(info.target.y);
    debugFields.targetZ.textContent = formatValue(info.target.z);

    lb3dDebugCompact.textContent = formatCameraConfig(info.compactConfig);
    lb3dDebugExact.textContent = formatCameraConfig(info.exactConfig, true);

    debugTicker = requestAnimationFrame(renderCameraDebug);
  }

  function startCameraDebug() {
    if (debugTicker) cancelAnimationFrame(debugTicker);
    renderCameraDebug();
  }

  function stopCameraDebug() {
    if (debugTicker) {
      cancelAnimationFrame(debugTicker);
      debugTicker = 0;
    }
    lastCameraDebugInfo = null;
    lb3dDebugStatus.textContent = 'Fechado';
  }

  async function copyCameraConfig(kind: 'compact' | 'exact') {
    if (!lastCameraDebugInfo) return;

    const text = kind === 'exact'
      ? formatCameraConfig(lastCameraDebugInfo.exactConfig, true)
      : formatCameraConfig(lastCameraDebugInfo.compactConfig);

    try {
      await navigator.clipboard.writeText(text);
      lb3dDebugStatus.textContent = kind === 'exact' ? 'Config exata copiada' : 'Config base copiada';
    } catch {
      lb3dDebugStatus.textContent = 'Falha ao copiar';
    }
  }

  function loadModelViewerModule() {
    return (modelViewerModulePromise ??= import('../lib/bedrock-renderer'));
  }

  /* ── Card HTML builder ───────────────────────────── */
  function cardMarkup(m: typeof models[number]): string {
    const has3d = 'model3d' in m && (m as any).model3d;
    const cam = 'camera' in m ? (m as any).camera : null;
    const render = 'render' in m ? (m as any).render : null;
    const camAttr = cam ? ` data-cam="${encodeURIComponent(JSON.stringify(cam))}"` : '';
    const renderAttr = render ? ` data-render="${encodeURIComponent(JSON.stringify(render))}"` : '';
    return `<div class="model-card" data-cat="${m.category}" data-src="${m.image}" data-title="${m.title}"${has3d ? ` data-model3d="${(m as any).model3d}"` : ''}${camAttr}${renderAttr}>
      <div class="model-card__inner">
        <img src="${m.image}" alt="${m.title}" loading="lazy" decoding="async" fetchpriority="low" draggable="false" />
        <div class="model-card__shine"></div>
        <div class="model-card__border"></div>
        ${has3d ? '<span class="model-card__3d-badge">3D</span>' : ''}
      </div>
    </div>`;
  }

  /* ── Build / rebuild the track ─────────────────── */
  function build() {
    const list = activeFilter === 'all'
      ? [...models]
      : models.filter(m => m.category === activeFilter);

    filteredCount = list.length;
    if (filteredCount === 0) {
      track.innerHTML = '';
      setW = 0;
      queueTicker();
      return;
    }

    const approxCard = 380;
    const setsNeeded = Math.max(Math.ceil((wrap.clientWidth * 3) / (filteredCount * approxCard)) + 1, 3);

    let html = '';
    for (let s = 0; s < setsNeeded; s++) {
      list.forEach(m => { html += cardMarkup(m); });
    }
    track.innerHTML = html;

    requestAnimationFrame(() => {
      const cards = track.querySelectorAll('.model-card');
      if (cards.length > filteredCount) {
        setW = (cards[filteredCount] as HTMLElement).offsetLeft - (cards[0] as HTMLElement).offsetLeft;
      }
      queueTicker();
    });

    pos = 0;
    track.style.transform = 'translate3d(0,0,0)';
  }

  function shouldTick() {
    return !document.hidden && setW > 0 && (
      isDrag ||
      Math.abs(velocity) > 0.15 ||
      (isVisible && !isHover && !isPaused)
    );
  }

  function stopTicker() {
    if (!ticking) return;
    cancelAnimationFrame(ticker);
    ticker = 0;
    ticking = false;
  }

  function queueTicker() {
    if (shouldTick()) {
      if (!ticking) {
        ticking = true;
        ticker = requestAnimationFrame(tick);
      }
      return;
    }

    stopTicker();
  }

  /* ── Animation loop ────────────────────────────── */
  function tick() {
    if (!ticking) return;

    if (isVisible && !isHover && !isDrag && !isPaused && setW > 0) {
      pos -= speed;
    }

    if (!isDrag && Math.abs(velocity) > 0.15) {
      pos += velocity;
      velocity *= 0.935;
    } else if (!isDrag) {
      velocity = 0;
    }

    if (setW > 0) {
      while (pos <= -setW) pos += setW;
      while (pos > 0) pos -= setW;
    }

    track.style.transform = `translate3d(${pos}px,0,0)`;

    if (shouldTick()) {
      ticker = requestAnimationFrame(tick);
    } else {
      ticking = false;
      ticker = 0;
    }
  }

  /* ── Visibility observer ───────────────────────── */
  const obs = new IntersectionObserver(([e]) => {
    isVisible = e.isIntersecting;
    queueTicker();
  }, { threshold: 0.08 });
  obs.observe(wrap);

  /* ── Hover ─────────────────────────────────────── */
  wrap.addEventListener('pointerenter', () => {
    isHover = true;
    queueTicker();
  });
  wrap.addEventListener('pointerleave', () => {
    isHover = false;
    isDrag = false;
    queueTicker();
  });

  /* ── Drag ──────────────────────────────────────── */
  function onDragMove(e: PointerEvent) {
    if (!isDrag) return;
    const diff = e.clientX - dragStartX;
    if (Math.abs(diff) > 4) clickOk = false;
    pos = dragOrigin + diff;
    velocity = (e.clientX - lastPtrX) * 0.45;
    lastPtrX = e.clientX;
  }

  function onDragEnd() {
    isDrag = false;
    document.removeEventListener('pointermove', onDragMove);
    document.removeEventListener('pointerup', onDragEnd);
    clearTimeout(resumeTimer);
    isPaused = true;
    queueTicker();
    resumeTimer = window.setTimeout(() => {
      isPaused = false;
      queueTicker();
    }, 1800);
  }

  wrap.addEventListener('pointerdown', (e) => {
    isDrag = true;
    clickOk = true;
    dragStartX = e.clientX;
    dragOrigin = pos;
    lastPtrX = e.clientX;
    velocity = 0;
    clearTimeout(resumeTimer);
    isPaused = false;
    document.addEventListener('pointermove', onDragMove);
    document.addEventListener('pointerup', onDragEnd, { once: true });
    queueTicker();
  });

  wrap.addEventListener('dragstart', (e) => e.preventDefault());

  /* ── Category filters ──────────────────────────── */
  document.querySelectorAll('.model-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.model-filter').forEach(f => f.classList.remove('active'));
      btn.classList.add('active');
      activeFilter = (btn as HTMLElement).dataset.category || 'all';

      track.style.opacity = '0';
      track.style.transition = 'opacity 0.22s ease';
      setTimeout(() => {
        build();
        track.style.opacity = '1';
      }, 220);
    });
  });

  /* ── Lightbox ──────────────────────────────────── */
  track.addEventListener('click', (e) => {
    if (!clickOk) return;
    const card = (e.target as HTMLElement).closest('.model-card') as HTMLElement | null;
    if (!card) return;

    const modelUrl = card.dataset.model3d;
    const title = card.dataset.title || '';

    // If model has 3D data, open the 3D viewer
    if (modelUrl) {
      const camRaw = card.dataset.cam || '';
      const renderRaw = card.dataset.render || '';
      open3DLightbox(modelUrl, title, camRaw, renderRaw);
      return;
    }

    // Otherwise open image lightbox
    const src = card.dataset.src;
    if (!src) return;
    lbImg.src = src;
    lbImg.alt = title;
    lbTitle.textContent = title;
    lbBadge.textContent = (card.dataset.cat || '').toUpperCase();
    lb.classList.add('is-open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    (window as any).__lenis?.stop();
  });

  async function open3DLightbox(modelUrl: string, title: string, camRaw: string, renderRaw: string) {
    lb3dTitle.textContent = title;
    lb3d.classList.add('is-open');
    lb3d.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    lb3dDebugStatus.textContent = 'Ao vivo';
    setDebugPanelOpen(defaultDebugOpen());
    updateLightingToggle(activeLightingMode);
    setLightingToggleDisabled(true);

    /* Stop Lenis so wheel events go to OrbitControls zoom */
    (window as any).__lenis?.stop();

    // Wait for layout to settle after the lightbox becomes visible
    await new Promise<void>((resolve) => {
      requestAnimationFrame(() => {
        requestAnimationFrame(() => resolve());
      });
    });

    const camera = parseCameraConfig(camRaw);
    const render = parseRenderConfig(renderRaw);

    try {
      const { createModelViewer } = await loadModelViewerModule();

      activeViewer = await createModelViewer({
        canvas: lb3dCanvas,
        modelUrl,
        interactive: true,
        camera,
        render,
        lightingMode: activeLightingMode,
      });
      activeViewer.resize();
      const appliedLightingMode = activeViewer.getLightingMode();
      updateLightingToggle(appliedLightingMode);
      persistLightingMode(appliedLightingMode);
      startCameraDebug();
    } catch (error) {
      console.error('Erro ao abrir viewer 3D', error);
      lb3dDebugStatus.textContent = 'Falha no viewer';
    } finally {
      setLightingToggleDisabled(false);
    }
  }

  function closeLb() {
    lb.classList.remove('is-open');
    lb.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    (window as any).__lenis?.start();
  }

  function close3DLb() {
    lb3d.classList.remove('is-open');
    lb3d.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    stopCameraDebug();
    setLightingToggleDisabled(false);
    /* Resume Lenis */
    (window as any).__lenis?.start();
    if (activeViewer) {
      activeViewer.dispose();
      activeViewer = null;
    }
  }

  lb.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('.model-lightbox__image')) return;
    closeLb();
  });

  lb3d.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('.model-lightbox-3d__body')) return;
    close3DLb();
  });

  lb3dDebugToggle.addEventListener('click', () => {
    const nextState = lb3dDebug.dataset.open !== 'true';
    setDebugPanelOpen(nextState);
  });

  lb3dLightingToggle.addEventListener('click', () => {
    const nextMode: ViewerLightingMode = activeLightingMode === 'enhanced' ? 'basic' : 'enhanced';

    if (activeViewer) {
      activeViewer.setLightingMode(nextMode);
      const appliedMode = activeViewer.getLightingMode();
      updateLightingToggle(appliedMode);
      persistLightingMode(appliedMode);
      lb3dDebugStatus.textContent = appliedMode === 'enhanced' ? 'Luz premium ligada' : 'Modo leve ligado';
      return;
    }

    updateLightingToggle(nextMode);
    persistLightingMode(nextMode);
  });

  lb3dCopyCompact.addEventListener('click', () => {
    void copyCameraConfig('compact');
  });

  lb3dCopyExact.addEventListener('click', () => {
    void copyCameraConfig('exact');
  });

  document.getElementById('lb3d-close')!.addEventListener('click', close3DLb);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeLb();
      close3DLb();
    }
  });

  // Handle window resize for 3D viewer
  window.addEventListener('resize', () => {
    activeViewer?.resize();
  });

  document.addEventListener('visibilitychange', queueTicker);

  /* ── Init ──────────────────────────────────────── */
  updateLightingToggle(activeLightingMode);
  build();
  queueTicker();

  let resizeTimer = 0;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(build, 300);
  });
</script>