---
import { navigation, socialLinks } from '../data/site';

const year = new Date().getFullYear();

const iconMap: Record<string, string> = {
  instagram: 'hn-instagram',
  linkedin: 'hn-linkedin',
  behance: 'hn-behance',
  github: 'hn-github',
};
---

<!-- Hidden canvas for generating dissolve mask -->
<canvas class="footer__mask-canvas" id="pixel-dissolve-mask" aria-hidden="true"></canvas>

<footer class="footer" id="site-footer">
  <!-- Floating shapes -->
  <div class="footer__shape footer__shape--diamond" aria-hidden="true"></div>
  <div class="footer__shape footer__shape--ring" aria-hidden="true"></div>

  <div class="container-shell">
    <div class="footer__top reveal-up">
      <div class="footer__about">
        <div class="footer__logo">
          <div class="footer__mark" aria-hidden="true"></div>
          <span class="footer__brand">Atyz Modder</span>
        </div>
        <p class="footer__desc">
          Portfolio focado em direção visual, texturas, modelagem 3D e identidade de add-ons para Minecraft Bedrock.
        </p>
        <div class="footer__social" style="margin-top: 1.25rem;">
          {socialLinks.map((link) => (
            <a href={link.url} class="footer__social-link" aria-label={link.label}>
              <i class={`hn ${iconMap[link.icon] || 'hn-globe-solid'}`}></i>
            </a>
          ))}
        </div>
      </div>

      <div>
        <p class="footer__col-title">Navegação</p>
        <nav aria-label="Links rápidos" class="footer__nav">
          {navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>
      </div>

      <div>
        <p class="footer__col-title">Contato</p>
        <nav class="footer__nav">
          <a href="mailto:contact.atylamodder@gmail.com">
            <i class="hn hn-message-solid"></i> Email
          </a>
          <a href="tel:+5538998694156">
            <i class="hn hn-phone-ringing-high-solid"></i> Telefone
          </a>
          <span style="color: var(--color-muted); font-size: 0.9rem; display: inline-flex; align-items: center; gap: 0.5rem;">
            <i class="hn hn-location-pin-solid"></i> Brazil
          </span>
        </nav>
      </div>
    </div>

    <div class="footer__bottom reveal-up" data-delay="0.15">
      <p>&copy; {year} Atyla Smith / Atyz. Todos os direitos reservados.</p>
      <div class="footer__bottom-links">
        <a href="#about">Sobre</a>
        <a href="#projects">Projetos</a>
        <a href="#contact">Contato</a>
      </div>
    </div>
  </div>
</footer>

<script>
  const footer = document.getElementById('site-footer');
  const cvs = document.getElementById('pixel-dissolve-mask') as HTMLCanvasElement | null;

  if (footer && cvs) {
    const footerEl = footer;
    const canvas = cvs;
    const ctx = canvas.getContext('2d')!;
    const perfTier = (window as any).__perfTier;
    const animateMask = !perfTier?.isLowEnd && !perfTier?.isReducedMotion;

    /* pixels that float away from the dissolve edge */
    const MAX_P = animateMask ? 40 : 0;
    const FRAME_MS = 1000 / 12;
    type P = { x:number; y:number; vx:number; vy:number; life:number; decay:number; sz:number };
    let w = 0, h = 0, maskH = 0, cols = 0, rows = 0, totalRows = 0, px = 10;
    let grid: number[][] = [];
    let parts: P[] = [];
    let raf = 0, on = false, isVisible = false, phase = 0, lastFrame = 0;

    const hash = (x: number, y: number) => {
      let v = ((x * 374761393 + y * 668265263) >>> 0);
      v = ((v ^ (v >> 13)) * 1274126177) >>> 0;
      return (v & 0x7fffffff) / 0x7fffffff;
    };

    function setup() {
      const rect = footerEl.getBoundingClientRect();
      w = Math.max(Math.round(rect.width), 1);
      h = Math.max(Math.round(rect.height), 1);
      maskH = 200;                          /* dissolve zone height */
      px = w < 600 ? 7 : w < 1024 ? 10 : 12;
      cols = Math.ceil(w / px);
      rows = Math.ceil(maskH / px);
      totalRows = Math.ceil(h / px);
      canvas.width = cols;
      canvas.height = totalRows;
      ctx.imageSmoothingEnabled = false;
      grid = [];
      parts = [];

      footerEl.style.setProperty('mask-size', '100% 100%');
      footerEl.style.setProperty('-webkit-mask-size', '100% 100%');
      footerEl.style.setProperty('mask-repeat', 'no-repeat');
      footerEl.style.setProperty('-webkit-mask-repeat', 'no-repeat');

      for (let ry = 0; ry < rows; ry++) {
        grid[ry] = [];
        const pct = ry / Math.max(rows - 1, 1); /* 0=top(sparse) 1=bottom(solid) */

        if (pct >= 0.82) {
          for (let c = 0; c < cols; c++) grid[ry][c] = 1;
          continue;
        }
        const density = Math.pow(pct, 1.8);
        for (let c = 0; c < cols; c++) grid[ry][c] = hash(c, ry) < density ? 1 : 0;
      }
      drawMask();
      applyMask();
    }

    function spawn() {
      if (!animateMask || parts.length >= MAX_P) return;
      const ry = Math.floor(rows * 0.08 + Math.random() * rows * 0.45);
      const cx = Math.floor(Math.random() * cols);
      parts.push({
        x: cx,
        y: ry,
        vx: (Math.random() - 0.5) * 0.12,
        vy: -(0.08 + Math.random() * 0.22),
        life: 1,
        decay: 0.02 + Math.random() * 0.02,
        sz: 1 + Math.random(),
      });
    }

    function applyMask() {
      const url = canvas.toDataURL();
      footerEl.style.setProperty('mask-image', `url(${url})`);
      footerEl.style.setProperty('-webkit-mask-image', `url(${url})`);
    }

    function drawMask() {
      ctx.clearRect(0, 0, cols, totalRows);

      /* ── dissolve zone (top 200px): pixelated alpha mask ── */
      for (let ry = 0; ry < rows; ry++) {
        const pct = ry / Math.max(rows - 1, 1);
        for (let cx = 0; cx < cols; cx++) {
          if (!grid[ry][cx]) continue;
          let a = 1;
          if (animateMask && pct < 0.55) {
            a = Math.sin(phase * 0.24 + hash(cx, ry) * 6.2832) * 0.15 + 0.85;
          }
          ctx.fillStyle = `rgba(255,255,255,${a})`;
          ctx.fillRect(cx, ry, 1, 1);
        }
      }

      /* ── floating particles (detaching pixels) ── */
      for (let i = parts.length - 1; i >= 0; i--) {
        const p = parts[i];
        p.x += p.vx;
        p.y += p.vy;
        p.vy *= 0.997;
        p.life -= p.decay;
        if (p.life <= 0) { parts.splice(i, 1); continue; }
        ctx.fillStyle = `rgba(255,255,255,${p.life * p.life})`;
        const size = Math.max(1, Math.round(p.sz));
        ctx.fillRect(
          Math.round(p.x),
          Math.round(p.y),
          size,
          size,
        );
      }

      /* ── rest of footer (below dissolve zone): fully visible ── */
      ctx.fillStyle = '#fff';
      ctx.fillRect(0, rows, cols, Math.max(totalRows - rows, 0));
    }

    function renderStatic() {
      phase = 0;
      drawMask();
      applyMask();
    }

    function stop() {
      on = false;
      if (raf) {
        cancelAnimationFrame(raf);
        raf = 0;
      }
    }

    function start() {
      if (!animateMask || on || document.hidden || !isVisible) return;
      on = true;
      lastFrame = 0;
      raf = requestAnimationFrame(frame);
    }

    function frame(now: number) {
      if (!on) return;

      if (lastFrame && now - lastFrame < FRAME_MS) {
        raf = requestAnimationFrame(frame);
        return;
      }

      lastFrame = now;
      phase++;

      if (Math.random() < 0.08) spawn();
      if (phase % 6 === 0) spawn();

      drawMask();
      applyMask();

      if (on) raf = requestAnimationFrame(frame);
    }

    const obs = new IntersectionObserver(([e]) => {
      isVisible = e.isIntersecting;
      if (animateMask) {
        if (isVisible) start();
        else stop();
        return;
      }

      if (isVisible) renderStatic();
    }, { threshold: 0.01 });

    setup();
  obs.observe(footerEl);

    if (!animateMask) {
      renderStatic();
    }

    document.addEventListener('visibilitychange', () => {
      if (!animateMask) return;
      if (document.hidden) {
        stop();
      } else {
        start();
      }
    });

    window.addEventListener('resize', () => {
      stop();
      setup();
      if (animateMask) {
        start();
      } else {
        renderStatic();
      }
    });
  }
</script>