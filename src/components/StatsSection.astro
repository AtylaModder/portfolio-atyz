---
import { stats } from '../data/site';
---

<section class="stats">
  <div class="container-shell">
    <div class="stats__grid reveal-stagger reveal-up">
      {stats.map((stat) => (
        <div class="stats__item">
          <div class="stats__number-wrap">
            <span class="stats__number" data-counter={stat.value}>0</span>
            <span class="stats__suffix">{stat.suffix}</span>
          </div>
          <p class="stats__label">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
