---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { siteMeta } from '../data/site';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
} = Astro.props;

const pageTitle = title === siteMeta.title ? title : `${title} | ${siteMeta.shortTitle}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? siteMeta.url).toString();
const ogImage = new URL(siteMeta.ogImage, Astro.site ?? siteMeta.url).toString();
const enableVercelObservability = import.meta.env.PROD;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={siteMeta.keywords.join(', ')} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#0f1318" />
    <meta name="author" content="Atyla Smith" />
    <meta name="google-site-verification" content="uO5c-pTAHFh7L360XbufMQ0SMnG75KztLwGSEneOWiQ" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Atyla Smith",
      "alternateName": "Atyz Modder",
      "url": "https://atyzmodder.com",
      "image": ogImage,
      "jobTitle": "3D Modeler & Texture Artist",
      "description": siteMeta.description,
      "knowsAbout": ["Minecraft Bedrock", "3D Modeling", "Texture Art", "PBR", "Add-on Development", "Graphic Design"],
      "sameAs": []
    })} />
    <ClientRouter />
    <script is:inline>
    (function(){
      var h=document.documentElement;
      var t=window.matchMedia('(pointer: coarse)').matches;
      var r=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var c=navigator.hardwareConcurrency||4;
      var l=c<4;
      var s=typeof CSS!=='undefined'&&CSS.supports&&CSS.supports('backdrop-filter','blur(1px)');
      var nb=!s||(l&&t);
      if(t)h.classList.add('perf-touch');
      if(r)h.classList.add('perf-reduced-motion');
      if(l)h.classList.add('perf-low-end');
      if(nb)h.classList.add('perf-no-backdrop');
      window.__perfTier={isTouch:t,isReducedMotion:r,isLowEnd:l,noBackdrop:nb,isMobile:t||window.innerWidth<768};
    })();
    </script>
  </head>
  <body class="is-loading">
    <div id="geo-bg" aria-hidden="true" transition:persist transition:name="geo-bg">
      <canvas class="geo-layer geo-layer--far"></canvas>
      <canvas class="geo-layer geo-layer--mid"></canvas>
      <canvas class="geo-layer geo-layer--near"></canvas>
    </div>
    <slot />
    {enableVercelObservability && <Analytics />}
    {enableVercelObservability && <SpeedInsights />}

    <script>
      import { initGeoBackground } from '../lib/geo-background';
      import { initRevealAnimations } from '../scripts/animations';
      import { initMicrointeractions } from '../scripts/microinteractions';
      import { initCustomCursor } from '../scripts/custom-cursor';
      import { getPerfTier, getParallaxScale, monitorFrameRate } from '../scripts/perf-tier';
      import { initCountUpStats } from '../scripts/countup-stats';
      import Lenis from 'lenis';
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      let geoInitialized = false;
      let lenis: Lenis | null = null;
      let lenisTicker: ((time: number) => void) | null = null;
      let heroParticlesModulePromise: Promise<typeof import('../scripts/hero-particles')> | null = null;
      let heroTypedModulePromise: Promise<typeof import('../scripts/hero-typed')> | null = null;
      let pageInitialized = false;
      let pageFinalized = false;
      let pagePrepared = false;
      let loaderFailSafe = 0;

      /* Expose Lenis globally so lightboxes can stop/start it */
      (window as any).__lenis = null;

      function loadHeroParticlesModule() {
        return (heroParticlesModulePromise ??= import('../scripts/hero-particles'));
      }

      function loadHeroTypedModule() {
        return (heroTypedModulePromise ??= import('../scripts/hero-typed'));
      }

      /* ── Detect touch-only devices ── */
      const isTouchDevice = () =>
        'ontouchstart' in window && navigator.maxTouchPoints > 0 && !window.matchMedia('(pointer: fine)').matches;

      /* ── Initialize / reinitialize Lenis ── */
      function initLenis() {
        if (lenis) { lenis.destroy(); lenis = null; }
        if (lenisTicker) {
          gsap.ticker.remove(lenisTicker);
          lenisTicker = null;
        }
        (window as any).__lenis = null;

        /* Skip Lenis on touch devices to avoid scroll jank */
        if (isTouchDevice()) return;

        lenis = new Lenis({
          lerp: 0.075,
          wheelMultiplier: 1,
          touchMultiplier: 1.5,
          syncTouch: false,
        });

        /* Expose globally */
        (window as any).__lenis = lenis;

        /* Connect Lenis → ScrollTrigger */
        lenis.on('scroll', ScrollTrigger.update);
        lenisTicker = (time) => { lenis?.raf(time * 1000); };
        gsap.ticker.add(lenisTicker);
        gsap.ticker.lagSmoothing(0);
      }

      async function initHeroParticlesIfNeeded() {
        const tier = getPerfTier();
        if (tier.isLowEnd || tier.isTouch || tier.isReducedMotion) return;
        const { initHeroParticles } = await loadHeroParticlesModule();
        initHeroParticles();
      }

      async function initHeroTypedLazy() {
        const { initHeroTyped } = await loadHeroTypedModule();
        initHeroTyped();
      }

      function scheduleDeferredWork(task: () => void, timeout = 600) {
        if ('requestIdleCallback' in window) {
          (window as any).requestIdleCallback(task, { timeout });
          return;
        }

        globalThis.setTimeout(task, Math.min(timeout, 450));
      }

      function preparePageExperience() {
        if (pagePrepared) return;
        pagePrepared = true;

        setupScrollAnimations();
        initRevealAnimations();

        /* Small warm-up so hero typing doesn't parse on first visible frame */
        void loadHeroTypedModule();
      }

      function finalizePageLoad() {
        if (pageFinalized) return;
        pageFinalized = true;

        if (loaderFailSafe) {
          window.clearTimeout(loaderFailSafe);
          loaderFailSafe = 0;
        }

        const pageWrap = document.querySelector('.page-wrap') as HTMLElement | null;
        const tier = getPerfTier();

        preparePageExperience();

        document.body.classList.remove('is-loading');
        if (pageWrap) pageWrap.style.opacity = '1';

        animateHero();

        scheduleDeferredWork(() => {
          if (!tier.isTouch) initCustomCursor();
        }, 180);

        scheduleDeferredWork(() => {
          if (!tier.isReducedMotion) initMicrointeractions();
        }, 420);

        scheduleDeferredWork(() => {
          void initHeroParticlesIfNeeded();
        }, 950);

        window.setTimeout(() => {
          monitorFrameRate();
        }, 1400);
      }

      function hideLoaderImmediately(loader: HTMLElement | null) {
        if (loader) {
          gsap.killTweensOf(loader);
          const loaderLogo = document.getElementById('loader-logo');
          if (loaderLogo) gsap.killTweensOf(loaderLogo);
          loader.style.opacity = '0';
          loader.style.display = 'none';
        }

        finalizePageLoad();
      }

      function animateLoaderOut(loader: HTMLElement) {
        if (pageFinalized) return;

        if (loaderFailSafe) {
          window.clearTimeout(loaderFailSafe);
          loaderFailSafe = 0;
        }

        /* Stop the spin — settle the diamond before flying */
        const mark = loader.querySelector('.loader__mark') as HTMLElement | null;
        if (mark) mark.style.animation = 'none';

        const loaderLogo = document.getElementById('loader-logo') as HTMLElement | null;

        gsap.to(loader, {
          opacity: 0,
          duration: 0.52,
          delay: 0.12,
          ease: 'power2.inOut',
          onStart: () => {
            if (loaderLogo) {
              gsap.to(loaderLogo, {
                y: -10,
                scale: 0.965,
                filter: 'blur(1.5px)',
                duration: 0.48,
                ease: 'power3.inOut',
              });
            }
          },
          onComplete: () => {
            loader.style.display = 'none';
            finalizePageLoad();
          },
        });
      }

      /* ── Smooth scroll for hash links without changing URL ── */
      document.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest('a[href^="#"]') as HTMLAnchorElement | null;
        if (!link) return;

        const id = link.getAttribute('href')!.slice(1);
        if (!id) return;

        const target = document.getElementById(id);
        if (!target) return;

        e.preventDefault();
        if (lenis) {
          lenis.scrollTo(target, { offset: 0 });
        } else {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });

      function handlePageLoad() {
        if (pageInitialized) return;
        pageInitialized = true;

        /* ── Always start at the top on load/reload ── */
        history.scrollRestoration = 'manual';
        window.scrollTo(0, 0);

        /* ── Lenis smooth scroll ── */
        initLenis();

        /* ── Geo background (persisted — init once) ── */
        if (!geoInitialized) {
          initGeoBackground();
          geoInitialized = true;
        }

        /* ── Clean up previous ScrollTriggers on navigation ── */
        ScrollTrigger.getAll().forEach((t) => t.kill());

        pagePrepared = false;

        /* ── Loading Screen ────────────────────────── */
        const loader = document.getElementById('loader');

        loaderFailSafe = window.setTimeout(() => {
          hideLoaderImmediately(loader);
        }, 4200);

        if (loader) {
          /* Wait for real page readiness, but never let fonts hold the loader for long */
          const fontsReady = document.fonts?.ready
            ? Promise.race([
                document.fonts.ready,
                new Promise<void>((res) => setTimeout(res, 1400)),
              ])
            : Promise.resolve();

          const criticalImages = Array.from(
            document.querySelectorAll<HTMLImageElement>('.hero img, img[data-loader-critical], [data-loader-critical] img')
          );
          const imagePromises = criticalImages
            .filter((img) => !img.complete)
            .map((img) => new Promise<void>((res) => {
              img.addEventListener('load', () => res(), { once: true });
              img.addEventListener('error', () => res(), { once: true });
            }));

          /* Loader should feel deliberate, but still fail open before feeling stuck */
          const minWait = new Promise<void>((res) => setTimeout(res, 1250));
          const safetyTimeout = new Promise<void>((res) => setTimeout(res, 3400));

          const contentReady = Promise.all([fontsReady, ...imagePromises, minWait]);
          Promise.race([contentReady, safetyTimeout])
            .then(() => {
              preparePageExperience();
              animateLoaderOut(loader);
            })
            .catch(() => {
              hideLoaderImmediately(loader);
            });
        } else {
          finalizePageLoad();
        }
      }

      function bootPageLoad() {
        try {
          handlePageLoad();
        } catch {
          hideLoaderImmediately(document.getElementById('loader'));
        }
      }

      document.addEventListener('astro:page-load', bootPageLoad);

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootPageLoad, { once: true });
      } else {
        queueMicrotask(bootPageLoad);
      }

      /* ── Hero Entrance ─────────────────────────── */
      function animateHero() {
        const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

        tl.from('.hero__tag', { y: 40, opacity: 0, duration: 0.8 })
          .from('.hero__title', { y: 60, opacity: 0, duration: 1 }, '-=0.5')
          .from('.hero__subtitle', { y: 40, opacity: 0, duration: 0.8 }, '-=0.6')
          .from('.hero__cta', { y: 30, opacity: 0, duration: 0.7 }, '-=0.4')
          .from('.hero__scroll', { opacity: 0, duration: 0.6 }, '-=0.2')
          .call(() => { void initHeroTypedLazy(); }, [], '-=0.3');
      }

      /* ── All Scroll-Driven Animations ──────────── */
      function setupScrollAnimations() {
        const pScale = getParallaxScale();

        /* Parallax shapes in hero */
        document.querySelectorAll('[data-parallax]').forEach((el) => {
          const speed = parseFloat((el as HTMLElement).dataset.parallax || '0.5') * pScale;
          if (speed === 0) return; // reduced-motion — skip entirely
          gsap.to(el, {
            y: () => window.innerHeight * speed * -0.4,
            scrollTrigger: {
              trigger: '.hero',
              start: 'top top',
              end: 'bottom top',
              scrub: 1,
            },
          });
        });

        /* Header scroll state */
        const header = document.getElementById('site-header');
        if (header) {
          ScrollTrigger.create({
            start: 80,
            onUpdate: (self) => {
              if (self.direction === 1 && window.scrollY > 80) {
                header.classList.add('is-scrolled');
              } else if (window.scrollY <= 80) {
                header.classList.remove('is-scrolled');
              }
            },
          });
        }

        /* Stats counter animation — CountUp.js with IntersectionObserver */
        initCountUpStats();
      }
    </script>
  </body>
</html>